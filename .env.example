# =============================================================================
# Désordre Radio — environment for docker-compose
# Copy to .env and replace every "changeme"/secret value before deploying.
# Generate secrets with:  openssl rand -base64 32
# =============================================================================

# ---- Domains / TLS (Caddy) --------------------------------------------------
# Point these A/AAAA records at the VPS. Caddy auto-provisions Let's Encrypt.
CADDY_EMAIL=admin@example.com
SITE_DOMAIN=desordre.radio
CMS_DOMAIN=cms.desordre.radio
STREAM_DOMAIN=stream.desordre.radio
MEDIA_DOMAIN=media.desordre.radio

# ---- Strapi secrets (REQUIRED) ----------------------------------------------
APP_KEYS=changeme_key1,changeme_key2
API_TOKEN_SALT=changeme_api_token_salt
ADMIN_JWT_SECRET=changeme_admin_jwt_secret
TRANSFER_TOKEN_SALT=changeme_transfer_token_salt
JWT_SECRET=changeme_jwt_secret
ENCRYPTION_KEY=changeme_encryption_key

# ---- Database (Postgres) ----------------------------------------------------
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=changeme_db_password

# ---- Object storage for media (S3-compatible, NOT AWS) ----------------------
# The provider speaks the S3 PROTOCOL; it works with any S3-compatible store.
# Default below = self-hosted MinIO in this compose → data stays on YOUR
# European VPS (most sovereign option). Leave S3_BUCKET empty to fall back to
# Strapi's local disk uploads.
#
# To use a managed EUROPEAN provider instead, drop the `minio` service and set
# S3_ENDPOINT / S3_REGION / keys accordingly. Examples:
#   Scaleway (FR/NL/PL): S3_ENDPOINT=https://s3.fr-par.scw.cloud   S3_REGION=fr-par
#   OVHcloud (EU):       S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net S3_REGION=gra
#   Exoscale (CH):       S3_ENDPOINT=https://sos-ch-gva-2.exo.io    S3_REGION=ch-gva-2
#   Hetzner (DE/FI):     S3_ENDPOINT=https://fsn1.your-objectstorage.com S3_REGION=fsn1
#   Infomaniak (CH):     S3_ENDPOINT=https://s3.pub1.infomaniak.cloud  S3_REGION=eu-central
S3_BUCKET=media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=changeme_minio_password
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
# Public base URL files are served from (your media domain, or the provider/CDN
# URL). For self-hosted MinIO this is the Caddy media domain above.
CDN_URL=https://media.desordre.radio/media

# ---- Icecast ----------------------------------------------------------------
ICECAST_SOURCE_PASSWORD=changeme_source
ICECAST_RELAY_PASSWORD=changeme_relay
ICECAST_ADMIN_PASSWORD=changeme_admin
ICECAST_HOSTNAME=stream.desordre.radio
ICECAST_MOUNT=stream

# ---- Live input (encoder / OBS → Liquidsoap harbor) -------------------------
LIVE_SOURCE_PASSWORD=changeme_live

# ---- Worker -----------------------------------------------------------------
# Strapi API token with READ on tracks/playlists/schedules and CREATE/UPDATE on
# now-playing + now-playing-history. Create in Strapi admin → Settings → API
# Tokens after first boot, then `docker compose up -d worker`.
STRAPI_API_TOKEN=
RADIO_TIMEZONE=Europe/Paris
# Delay now-playing updates to match the audio listeners actually hear (ms).
STREAM_BUFFER_DELAY_MS=10000
# Shared secret Liquidsoap sends with metadata POSTs (defends the write path).
METADATA_SECRET=changeme_metadata_secret
# Optional dedicated secret for operator POST /play-now requests. If omitted,
# the worker reuses METADATA_SECRET for that endpoint too.
PLAY_NOW_SECRET=
# Strapi admin uses this internal worker URL to proxy Skip / Play Now securely.
RADIO_CONTROL_WORKER_URL=http://worker:3001

# ---- Public URLs baked into the frontend (browser-facing, build-time) -------
PUBLIC_STRAPI_URL=https://cms.desordre.radio
PUBLIC_STREAM_URL=https://stream.desordre.radio/stream
PUBLIC_NOW_PLAYING_URL=https://cms.desordre.radio/api/now-playing
PUBLIC_NOW_PLAYING_SSE_URL=https://desordre.radio/now-playing/stream
