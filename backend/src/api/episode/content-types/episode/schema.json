{
  "kind": "collectionType",
  "collectionName": "episodes",
  "info": {
    "singularName": "episode",
    "pluralName": "episodes",
    "displayName": "Episode",
    "description": "An on-demand replay recording of a show."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text"
    },
    "audioUrl": {
      "type": "string",
      "description": "External audio URL. Takes precedence over the uploaded media."
    },
    "audio": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["audios"]
    },
    "duration": {
      "type": "integer",
      "description": "Duration in seconds."
    },
    "airedAt": {
      "type": "datetime"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "show": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::show.show",
      "inversedBy": "episodes"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.rich-text",
        "shared.quote",
        "shared.media",
        "shared.slider"
      ]
    }
  }
}
