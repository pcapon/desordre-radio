{
  "kind": "collectionType",
  "collectionName": "playlists",
  "info": {
    "singularName": "playlist",
    "pluralName": "playlists",
    "displayName": "Playlist",
    "description": "An ordered or shuffled set of tracks the autoDJ can draw from."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "kind": {
      "type": "enumeration",
      "enum": ["rotation", "themed", "jingle", "fallback"],
      "default": "rotation"
    },
    "shuffle": {
      "type": "boolean",
      "default": true
    },
    "isDefault": {
      "type": "boolean",
      "default": false,
      "description": "The fallback rotation the autoDJ uses when nothing is scheduled."
    },
    "tracks": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::track.track",
      "inversedBy": "playlists"
    }
  }
}
