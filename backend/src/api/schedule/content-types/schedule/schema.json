{
  "kind": "collectionType",
  "collectionName": "schedules",
  "info": {
    "singularName": "schedule",
    "pluralName": "schedules",
    "displayName": "Schedule",
    "description": "A recurring time slot during which a playlist takes over the autoDJ."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "playlist": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::playlist.playlist"
    },
    "daysOfWeek": {
      "type": "json",
      "description": "Array of weekdays this slot is active, e.g. [\"mon\",\"wed\",\"fri\"]. Empty/null = every day."
    },
    "startTime": {
      "type": "time",
      "required": true
    },
    "endTime": {
      "type": "time",
      "required": true
    },
    "priority": {
      "type": "integer",
      "default": 10,
      "description": "Higher priority wins when two slots overlap."
    },
    "timezone": {
      "type": "string",
      "default": "Europe/Paris"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  }
}
